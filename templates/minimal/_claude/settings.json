{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; [ -n \"$f\" ] && pnpm exec prettier --write \"$f\" --ignore-unknown; } 2>/dev/null || true",
            "statusMessage": "Prettier..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(pnpm:*)",
      "Bash(codex:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(./.scripts/*)"
    ],
    "deny": ["Bash(rm -rf /*)", "Bash(git push --force*)"]
  }
}
